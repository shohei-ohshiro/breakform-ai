# BreakForm AI - Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# Required: Anthropic (Claude API)
# ============================================
# Used for AI-powered advice generation after rule-based analysis
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ============================================
# Required: Supabase
# ============================================
# Project URL and keys from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ============================================
# Optional: Stripe (Phase 2 - not needed for MVP)
# ============================================
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
